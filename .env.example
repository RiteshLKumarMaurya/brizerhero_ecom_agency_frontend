# ============================================================
# BrizerHero Frontend — Environment Variables
# Copy this file to .env.local for local development
# NEVER commit .env.local to version control
# ============================================================

# ── Backend API ──────────────────────────────────────────────
# The base URL of your BrizerHero backend API
# No trailing slash
NEXT_PUBLIC_API_URL=https://api.brizerhero.com

# ── Site URL ─────────────────────────────────────────────────
# Used for SEO metadata, canonical URLs, sitemap, OG images
# No trailing slash
NEXT_PUBLIC_SITE_URL=https://brizerhero.com

# ── Google OAuth ─────────────────────────────────────────────
# Get this from: https://console.cloud.google.com/
# Create a project → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized JavaScript origins: https://brizerhero.com (and http://localhost:3000 for dev)
# Authorized redirect URIs: not needed for GSI (One Tap uses callback, not redirect)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=995240676409-kg49dqedvqdremj9ehmpq7qufrfmn0h9.apps.googleusercontent.com

# ── CDN / Media ──────────────────────────────────────────────
# Base URL for your media CDN (Cloudflare, CloudFront, etc.)
# Images stored in the backend are served from this URL
# Example: https://cdn.brizerhero.com
NEXT_PUBLIC_CDN_URL=https://cdn.brizerhero.com

# ── Google Search Console ────────────────────────────────────
# Optional: used for meta verification tag
# Get from: https://search.google.com/search-console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ── Analytics (optional) ─────────────────────────────────────
# Google Analytics 4 Measurement ID
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── Feature Flags (optional) ────────────────────────────────
# Set to "true" to enable React Query DevTools in development
NEXT_PUBLIC_ENABLE_QUERY_DEVTOOLS=false
